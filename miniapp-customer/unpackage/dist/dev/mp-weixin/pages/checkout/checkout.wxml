<view class="checkout data-v-fd186f5c"><view class="page-title data-v-fd186f5c">确认订单</view><view class="address-section data-v-fd186f5c" bindtap="{{e}}"><block wx:if="{{a}}"><view class="addr-kicker data-v-fd186f5c">配送至</view><view class="addr-top data-v-fd186f5c"><text class="addr-name data-v-fd186f5c">{{b}}</text><text class="addr-tel data-v-fd186f5c">{{c}}</text></view><view class="addr-detail data-v-fd186f5c">{{d}}</view></block><block wx:else><view class="data-v-fd186f5c"><view class="addr-kicker data-v-fd186f5c">配送地址</view><text class="addr-empty data-v-fd186f5c">请选择配送地址</text></view><text class="arrow data-v-fd186f5c">›</text></block></view><view class="goods-section data-v-fd186f5c"><view class="section-title data-v-fd186f5c">商品明细</view><view wx:for="{{f}}" wx:for-item="item" wx:key="h" class="goods-item data-v-fd186f5c"><image src="{{item.a}}" mode="aspectFill" class="goods-img data-v-fd186f5c"/><view class="goods-info data-v-fd186f5c"><view class="goods-name data-v-fd186f5c">{{item.b}}</view><view wx:if="{{item.c}}" class="goods-sku data-v-fd186f5c">{{item.d}}</view><view class="goods-price data-v-fd186f5c">¥{{item.e}} × {{item.f}}</view></view><view class="goods-total data-v-fd186f5c">¥{{item.g}}</view></view></view><view class="remark-section data-v-fd186f5c"><text class="data-v-fd186f5c">备注</text><input placeholder="口味、餐具等需求" placeholder-class="placeholder" class="remark-input data-v-fd186f5c" value="{{g}}" bindinput="{{h}}"/></view><view class="summary data-v-fd186f5c"><text class="data-v-fd186f5c">合计</text><text class="summary-price data-v-fd186f5c">¥{{i}}</text></view><button class="btn-pay data-v-fd186f5c" bindtap="{{j}}">提交订单</button></view>